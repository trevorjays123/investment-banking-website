{
  "version": 2,
  "builds": [
    { "src": "vercelBuild.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/vercelBuild.js" },
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/((?!api).*)", "dest": "/public/index.html" }
  ],
  "env": { "NODE_ENV": "production" }
}
